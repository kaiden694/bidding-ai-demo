# Railway 根目录 .dockerignore
# 避免把无关文件送入构建上下文，加速构建

# Git
.git
.gitignore

# 文档
*.md
docs/
deploy/

# 前端（backend Dockerfile 不需要）
frontend/

# 测试
backend/tests/
backend/scripts/
**/__pycache__/
*.pyc
.pytest_cache/

# 环境
.env
.env.*
!.env.example

# IDE
.trae/
.trae-cn/
.vscode/
.idea/

# 构建产物
frontend/admin/dist/
**/node_modules/
