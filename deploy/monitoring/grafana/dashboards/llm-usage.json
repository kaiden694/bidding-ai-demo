{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "LLM 用量大盘：请求总数 / 延迟分布 / 成功率 / 熔断状态",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "LLM 请求 QPS（按 provider）",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10}
        }
      },
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_requests_total[1m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "LLM 延迟分布（P50 / P95 / P99）",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10}
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, provider) (rate(llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} P99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "成功率",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.8},
              {"color": "green", "value": 0.95}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(llm_requests_total{success=\"true\"[5m])) / sum(rate(llm_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "总请求数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "sum(llm_requests_total)", "refId": "A"}
      ]
    },
    {
      "title": "熔断器状态",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {"expr": "llm_circuit_breaker_active", "legendFormat": "熔断中的 provider 数", "refId": "A"}
      ]
    },
    {
      "title": "请求量按 provider 分布",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "expr": "sum by (provider) (llm_requests_total)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Provider 健康状态",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {
          "expr": "llm_provider_healthy",
          "legendFormat": "{{provider}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "失败请求数（按 provider）",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10}
        }
      },
      "targets": [
        {
          "expr": "sum by (provider) (rate(llm_requests_total{success=\"false\"}[5m]))",
          "legendFormat": "{{provider}} 失败",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["sbaw", "llm"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "LLM 用量",
  "uid": "sbaw-llm-usage",
  "version": 1,
  "weekStart": ""
}
