# =========================================================
# 智能招投标与合同合规 AI 工作台 — 环境变量样例
# 复制为 .env 并按实际环境填写
# =========================================================

# ---- 应用 ----
APP_NAME=smart-bidding-ai-workbench
APP_ENV=dev                      # dev | staging | prod
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ---- 安全 ----
SECRET_KEY=please-change-this-to-a-random-long-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# ---- PostgreSQL ----
# 本地开发环境（WSL2 + Ubuntu）：
#   - WSL Ubuntu 用户：hel（密码 123）
#   - PostgreSQL 已安装在 WSL Ubuntu 内
#   - 从 Windows 宿主机访问时，POSTGRES_HOST 用 WSL 的 IP 或 localhost（取决于 WSL2 端口转发）
#   - 在 WSL 内直接运行后端时，POSTGRES_HOST=localhost
# Docker Compose 部署时：POSTGRES_HOST=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sbaw
POSTGRES_USER=sbaw
POSTGRES_PASSWORD=sbaw_change_me
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- MinIO (对象存储) ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_change_me
MINIO_BUCKET=sbaw-files
MINIO_SECURE=false

# ---- LLM (OpenAI 兼容接口) ----
# 本地 vLLM/Ollama 或商业 API 均使用此接口
LLM_BASE_URL=http://llm:8000/v1
LLM_API_KEY=not-required-for-local
LLM_MODEL=qwen2.5-14b-instruct
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
# 多模型负载均衡（逗号分隔，留空则单模型）
LLM_FALLBACK_MODELS=

# ---- Embedding ----
EMBEDDING_BASE_URL=http://llm:8000/v1
EMBEDDING_API_KEY=not-required-for-local
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# ---- Reranker ----
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_TOP_K=5

# ---- RAG ----
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_RETRIEVE_TOP_K=20

# ---- Celery ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- CORS（前端地址，逗号分隔）----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
